{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'No build needed — static HTML site'",
  "outputDirectory": ".",
  "installCommand": "npm install --omit=dev --no-audit --no-fund",
  "rewrites": [
    { "source": "/api/delhivery/:action", "destination": "/api/delhivery?action=:action" }
  ],
  "crons": [
    {
      "path": "/api/whatsapp/abandoned-cart-cron",
      "schedule": "0 12 * * *"
    }
  ]
}
